%% Residual connections inside one Llama 3 decoder block.
%% Focus: each residual add keeps the current X and adds a sub-block update.
flowchart TB
    X0["Current token vectors<br/>X<br/>(residual stream)"]:::stream

    subgraph ATT["Attention sub-block produces update #1"]
        direction TB
        A1["RMSNorm<br/>prepare the signal"]:::op
        A2["Q / K / V projections"]:::op
        A3["RoPE<br/>position fingerprint on Q and K"]:::op
        A4["GQA attention<br/>score matches, block future tokens,<br/>normalize weights, mix Values"]:::op
        A5["Output projection<br/>turn mixed context back into 4096 dims"]:::op
        OUT1["attention update<br/>attn_out"]:::update

        A1 --> A2 --> A3 --> A4 --> A5 --> OUT1
    end

    KEEP1["preserved original X"]:::keep
    ADD1{{"Residual #1<br/>X = X + attn_out"}}:::add
    X1["After attention residual<br/>X_after_attn"]:::stream

    subgraph FFN["FFN sub-block produces update #2"]
        direction TB
        F1["RMSNorm<br/>prepare updated X"]:::op
        F2["SwiGLU FFN<br/>gate filters/amplifies features"]:::op
        F3["Down projection<br/>turn refinement back into 4096 dims"]:::op
        OUT2["FFN update<br/>ffn_out"]:::update

        F1 --> F2 --> F3 --> OUT2
    end

    KEEP2["preserved current X"]:::keep
    ADD2{{"Residual #2<br/>X = X + ffn_out"}}:::add
    X2["Layer output<br/>X_after_ffn<br/>(sent to next decoder block)"]:::stream

    RULE["Residual rule<br/>A sub-block does not replace X.<br/>It computes an update, then adds it back."]:::note
    WHY["Why not after RoPE or raw GQA?<br/>RoPE only changes Q/K scoring geometry.<br/>Raw GQA still needs output projection before it is a 4096-dim update."]:::note

    X0 --> A1
    X0 --> KEEP1
    OUT1 --> ADD1
    KEEP1 --> ADD1
    ADD1 --> X1

    X1 --> F1
    X1 --> KEEP2
    OUT2 --> ADD2
    KEEP2 --> ADD2
    ADD2 --> X2

    WHY -.-> A3
    WHY -.-> A5
    RULE -.-> ADD1
    RULE -.-> ADD2

    classDef stream fill:#e1f5fe,stroke:#0277bd,stroke-width:2px,color:#000;
    classDef op fill:#f5f5f5,stroke:#616161,stroke-width:1px,color:#000;
    classDef update fill:#fff3e0,stroke:#ef6c00,stroke-width:2px,color:#000;
    classDef keep fill:#fffde7,stroke:#f9a825,stroke-width:2px,color:#000;
    classDef add fill:#c8e6c9,stroke:#2e7d32,stroke-width:3px,color:#000;
    classDef note fill:#ede7f6,stroke:#5e35b1,stroke-width:2px,color:#000;

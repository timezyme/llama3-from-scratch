# GCP L4 testing config. Copy to `.l4-config.env` (gitignored) and fill in.
# Sourced by tools/provision_l4.sh and tools/test_l4.sh.

VM_NAME=cs265-l4
PREFERRED_ZONE=us-east1-c        # try this zone first; script falls back if exhausted
CUDA_VER=12.9                    # nvcc lives at /usr/local/cuda-${CUDA_VER}/bin
ARCH=sm_89                       # L4 = sm_89, A100 = sm_80, T4 = sm_75

# Optional: only if gcloud isn't on PATH
# GCLOUD_PATH=/Users/you/google-cloud-sdk/bin
